# ════════════════════════════════════════════════════
# OpenClaw Environment Variables
# Add these in Railway → your service → Variables tab
# ════════════════════════════════════════════════════

# ── REQUIRED ─────────────────────────────────────────
# Discord bot token (discord.com/developers/applications)
DISCORD_TOKEN=your_discord_bot_token

# Your Discord server ID (right-click server → Copy Server ID)
DISCORD_GUILD_ID=your_server_id

# Anthropic API key (console.anthropic.com)
# Used for: opportunity scanning, listing copy, strategy
ANTHROPIC_API_KEY=your_anthropic_key

# ── GLM CODING PLAN (optional but recommended) ───────
# Z.ai API key (z.ai → API settings)
# Used for: code generation (5x cheaper than Claude)
# Get the Lite plan (~$10/mo) at z.ai/subscribe
# If not set, OpenClaw falls back to Claude for code tasks
GLM_API_KEY=your_glm_api_key

# GLM model — GLM-5.1 for best coding, GLM-4.7 for faster/cheaper
GLM_CODE_MODEL=GLM-5.1

# ── GOAL ─────────────────────────────────────────────
CAPITAL_BUDGET=50
REVENUE_TARGET=500
TARGET_DAYS=30

# ── AGENT SCHEDULES (minutes) ────────────────────────
OPPORTUNITY_INTERVAL=240
REVENUE_INTERVAL=1440

# ── PLATFORM KEYS (add when accounts are ready) ──────
# ETSY_API_KEY=
# GUMROAD_ACCESS_TOKEN=
