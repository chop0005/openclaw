# ════════════════════════════════════════════════════
# OpenClaw Environment Variables — Railway Variables Tab
# ════════════════════════════════════════════════════

# ── REQUIRED ─────────────────────────────────────────
DISCORD_TOKEN=your_discord_bot_token
DISCORD_GUILD_ID=your_server_id
ANTHROPIC_API_KEY=your_anthropic_key

# ── AI MODELS ─────────────────────────────────────────
OPENAI_API_KEY=your_openai_key
GEMINI_API_KEY=your_gemini_key
DEEPSEEK_API_KEY=your_deepseek_key
GLM_API_KEY=your_glm_key
GLM_CODE_MODEL=GLM-5.1

# ── SELLING PLATFORMS ────────────────────────────────
ETSY_API_KEY=your_etsy_keystring
ETSY_ACCESS_TOKEN=your_etsy_oauth_token
ETSY_SHOP_ID=your_numeric_shop_id
GUMROAD_ACCESS_TOKEN=your_gumroad_token

# ── TRAFFIC ───────────────────────────────────────────
PINTEREST_ACCESS_TOKEN=your_pinterest_token
PINTEREST_BOARD_ID=your_board_id

# ── EMAIL / NEWSLETTER ───────────────────────────────
BEEHIIV_API_KEY=your_beehiiv_api_key
BEEHIIV_PUBLICATION_ID=your_pub_xxx_id

# ── GOAL ─────────────────────────────────────────────
CAPITAL_BUDGET=50
REVENUE_TARGET=500
TARGET_DAYS=30
OPPORTUNITY_INTERVAL=240
REVENUE_INTERVAL=1440
